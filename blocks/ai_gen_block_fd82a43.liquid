{% doc %}
  @prompt
    i want a benefits table us vs others 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-benefits-table-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-benefits-table__wrapper-{{ ai_gen_id }} {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  {% comment %} .ai-benefits-table__container-{{ ai_gen_id }} {
    min-width: 100%;
    border-collapse: collapse;
    background-color: {{ block.settings.table_background }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
  } {% endcomment %}
  .ai-benefits-table__container-arxlyogxoee1nvys3raigenblockfd82a43pzrcq8 {
  max-width: 780px !important;
  margin: 0 auto;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 4px 32px rgba(192, 96, 122, 0.12);
  }

  .ai-benefits-table__header-{{ ai_gen_id }} {
    background-color: {{ block.settings.header_background }};
  }

  .ai-benefits-table__header-cell-{{ ai_gen_id }} {
    padding: {{ block.settings.cell_padding }}px;
    text-align: center;
    font-size: {{ block.settings.header_font_size }}px;
    font-weight: 600;
    color: {{ block.settings.header_text_color }};
    border-bottom: 2px solid {{ block.settings.border_color }};
  }

  .ai-benefits-table__header-cell-{{ ai_gen_id }}:first-child {
    text-align: left;
    width: 40%;
  }

  .ai-benefits-table__header-cell-{{ ai_gen_id }}:nth-child(2) {
    background-color: {{ block.settings.us_column_background }};
    color: {{ block.settings.us_column_text_color }};
  }

  .ai-benefits-table__row-{{ ai_gen_id }} {
    border-bottom: 1px solid {{ block.settings.border_color }};
  }

  .ai-benefits-table__row-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  .ai-benefits-table__cell-{{ ai_gen_id }} {
    padding: {{ block.settings.cell_padding }}px;
    text-align: center;
    font-size: {{ block.settings.body_font_size }}px;
    color: {{ block.settings.body_text_color }};
  }

  .ai-benefits-table__cell-{{ ai_gen_id }}:first-child {
    text-align: left;
    font-weight: 500;
  }

  .ai-benefits-table__cell-{{ ai_gen_id }}:nth-child(2) {
    background-color: {{ block.settings.us_cell_background }};
  }

  .ai-benefits-table__icon-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
  }

  .ai-benefits-table__icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-benefits-table__checkmark-{{ ai_gen_id }} {
    color: {{ block.settings.checkmark_color }};
  }

  .ai-benefits-table__cross-{{ ai_gen_id }} {
    color: {{ block.settings.cross_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-benefits-table__header-cell-{{ ai_gen_id }},
    .ai-benefits-table__cell-{{ ai_gen_id }} {
      padding: {{ block.settings.cell_padding | times: 0.7 }}px;
      font-size: {{ block.settings.body_font_size | times: 0.9 }}px;
    }

    .ai-benefits-table__header-cell-{{ ai_gen_id }} {
      font-size: {{ block.settings.header_font_size | times: 0.9 }}px;
    }

    .ai-benefits-table__icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 }}px;
      height: {{ block.settings.icon_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<benefits-table-{{ ai_gen_id }}
  class="ai-benefits-table-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-benefits-table__wrapper-{{ ai_gen_id }}">
    <table class="ai-benefits-table__container-{{ ai_gen_id }}">
      <thead class="ai-benefits-table__header-{{ ai_gen_id }}">
        <tr>
          <th class="ai-benefits-table__header-cell-{{ ai_gen_id }}">{{ block.settings.feature_column_title }}</th>
          <th class="ai-benefits-table__header-cell-{{ ai_gen_id }}">{{ block.settings.us_column_title }}</th>
          <th class="ai-benefits-table__header-cell-{{ ai_gen_id }}">{{ block.settings.others_column_title }}</th>
        </tr>
      </thead>
      <tbody>
        {% for i in (1..8) %}
          {% liquid
            assign feature_key = 'feature_' | append: i
            assign us_key = 'us_' | append: i
            assign others_key = 'others_' | append: i

            assign feature_text = block.settings[feature_key]
            assign us_value = block.settings[us_key]
            assign others_value = block.settings[others_key]
          %}

          {% if feature_text != blank %}
            <tr class="ai-benefits-table__row-{{ ai_gen_id }}">
              <td class="ai-benefits-table__cell-{{ ai_gen_id }}">{{ feature_text }}</td>
              <td class="ai-benefits-table__cell-{{ ai_gen_id }}">
                {% if us_value %}
                  <span class="ai-benefits-table__icon-{{ ai_gen_id }} ai-benefits-table__checkmark-{{ ai_gen_id }}">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                  </span>
                {% else %}
                  <span class="ai-benefits-table__icon-{{ ai_gen_id }} ai-benefits-table__cross-{{ ai_gen_id }}">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="18" y1="6" x2="6" y2="18"></line>
                      <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                  </span>
                {% endif %}
              </td>
              <td class="ai-benefits-table__cell-{{ ai_gen_id }}">
                {% if others_value %}
                  <span class="ai-benefits-table__icon-{{ ai_gen_id }} ai-benefits-table__checkmark-{{ ai_gen_id }}">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                  </span>
                {% else %}
                  <span class="ai-benefits-table__icon-{{ ai_gen_id }} ai-benefits-table__cross-{{ ai_gen_id }}">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="18" y1="6" x2="6" y2="18"></line>
                      <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                  </span>
                {% endif %}
              </td>
            </tr>
          {% endif %}
        {% endfor %}
      </tbody>
    </table>
  </div>
</benefits-table-{{ ai_gen_id }}>

<script>
  (function() {
    class BenefitsTable{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('benefits-table-{{ ai_gen_id }}', BenefitsTable{{ ai_gen_id }});
  })();
</script>

