        "liquid": "<link href=\"https://fonts.googleapis.com/css2?family=Barlow:wght@400;600;700;800;900&display=swap\" rel=\"stylesheet\"> <style> .reviews-section { background: #fff5f8; padding: 32px 16px; width: 100%; box-sizing: border-box; font-family: 'Barlow', Arial, sans-serif; text-align: center; } .reviews-stars-row { display: flex; align-items: center; justify-content: center; gap: 8px; margin-bottom: 12px; } .reviews-stars { color: #e8a0b4; font-size: 20px; letter-spacing: 2px; } .reviews-rating-text { font-size: 15px; font-weight: 400; color: #333; } .reviews-title { font-size: 28px; font-weight: 900; color: #111; text-transform: uppercase; line-height: 1.1; margin: 0 0 24px; letter-spacing: 0.02em; } .reviews-tabs { display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; margin-bottom: 28px; } .reviews-tab { padding: 10px 20px; border-radius: 50px; border: 2px solid #ccc; background: #fff; font-size: 14px; font-weight: 700; color: #111; cursor: pointer; transition: all 0.2s ease; font-family: 'Barlow', Arial, sans-serif; } .reviews-tab:hover { border-color: #c0607a; color: #c0607a; } .reviews-tab.active { background: #c0607a; border-color: #c0607a; color: #fff; } .reviews-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; max-width: 1000px; margin: 0 auto 24px; } .review-card { display: flex; flex-direction: column; align-items: center; gap: 10px; padding: 0 12px; border-right: 1px solid #f0ccd6; } .review-card:last-child { border-right: none; } .review-card-stars { color: #e8a0b4; font-size: 18px; letter-spacing: 2px; } .review-card-text { font-size: 14px; font-weight: 400; color: #222; line-height: 1.6; text-align: center; } .review-card-author { font-size: 14px; font-weight: 700; color: #111; margin-top: 6px; } .reviews-dots { display: flex; justify-content: center; gap: 6px; margin-top: 8px; } .reviews-dot { width: 8px; height: 8px; border-radius: 50%; background: #ccc; cursor: pointer; transition: background 0.2s; } .reviews-dot.active { background: #c0607a; } @media (max-width: 599px) { .reviews-title { font-size: 18px; } .reviews-grid { grid-template-columns: 1fr; gap: 20px; } .review-card { border-right: none; border-bottom: 1px solid #f0ccd6; padding-bottom: 20px; } .review-card:last-child { border-bottom: none; } .reviews-tab { font-size: 12px; padding: 8px 14px; } } </style> <div class=\"reviews-section\"> <div class=\"reviews-stars-row\"> <span class=\"reviews-stars\">★★★★★</span> <span class=\"reviews-rating-text\">4.8 stars </span> </div> <h2 class=\"reviews-title\">Real Women. Real Results. Real Glow.</h2> <div class=\"reviews-tabs\"> <button class=\"reviews-tab active\" onclick=\"switchTab('results', event)\">Results</button> <button class=\"reviews-tab\" onclick=\"switchTab('quality', event)\">Quality</button> <button class=\"reviews-tab\" onclick=\"switchTab('value', event)\">Value</button> <button class=\"reviews-tab\" onclick=\"switchTab('delivery', event)\">Delivery</button> <button class=\"reviews-tab\" onclick=\"switchTab('repurchase', event)\">Would Buy Again</button> </div> <div class=\"reviews-grid\" id=\"reviews-grid\"></div> <div class=\"reviews-dots\" id=\"reviews-dots\"></div> </div> <script> const allReviews = { results: [ { text: \"My brows have never looked this clean and defined. The Tattoo Brow product literally changed my morning routine.\", author: \"Lara M., Beirut\" }, { text: \"The nose strips actually work. I've tried so many brands and this is the only one that cleared my pores visibly.\", author: \"Nour K., Jounieh\" }, { text: \"I was skeptical about the Boob Lift tape but it genuinely delivered. Wore it to a wedding and felt so confident.\", author: \"Maya R., Saida\" }, { text: \"Within one week my skin looked more even and glowy. I get so many compliments now.\", author: \"Rima H., Tripoli\" }, { text: \"The hairline powder is a game changer. I have a slightly high forehead and this made such a difference.\", author: \"Dina F., Beirut\" }, { text: \"Honestly did not expect results this fast. My brows look professionally done every single day.\", author: \"Sara A., Batroun\" }, ], quality: [ { text: \"The packaging is beautiful and the product feels premium. Not cheap at all for the price point.\", author: \"Joelle B., Beirut\" }, { text: \"I've used drugstore brands all my life and this is on another level. The texture and formula are excellent.\", author: \"Hana S., Zahle\" }, { text: \"The Tattoo Brow lasted all day through heat and humidity. Lebanese summer approved.\", author: \"Tanya M., Byblos\" }, { text: \"Products arrived in perfect condition, well packaged and sealed. Felt like a luxury purchase.\", author: \"Celine A., Achrafieh\" }, { text: \"Quality is consistent — I've ordered three times now and every time it's exactly as expected.\", author: \"Nadine T., Hamra\" }, { text: \"The nose strips are gentle on skin but still effective. No irritation at all, and I have sensitive skin.\", author: \"Rana K., Antelias\" }, ], value: [ { text: \"For the price I was expecting average. What I got was way above average. Incredible value.\", author: \"Mona G., Beirut\" }, { text: \"I used to spend triple this at salons for brow styling. Now I do it at home in 2 minutes.\", author: \"Rita S., Dbayeh\" }, { text: \"The Boob Lift tape pack has enough pieces to last months. Such good value for money.\", author: \"Lea J., Jounieh\" }, { text: \"Genuinely shocked at the quality for this price. I expected mediocre and got something I'd gift to friends.\", author: \"Carla N., Mar Mikhael\" }, { text: \"Best beauty purchase I've made this year. Results that usually cost way more.\", author: \"Yasmine F., Rabieh\" }, { text: \"Ordered on a budget and felt zero guilt after. Every product was worth it and then some.\", author: \"Mirna L., Baabda\" }, ], delivery: [ { text: \"Ordered on a Tuesday, arrived Thursday. Super fast and the package was well wrapped.\", author: \"Nadia R., Beirut\" }, { text: \"Delivery was smooth and the driver was polite. Cash on delivery made it so easy.\", author: \"Ines K., Tripoli\" }, { text: \"I was surprised how quickly it came. Even to my area which is usually delayed with other stores.\", author: \"Fatima M., Saida\" }, { text: \"Second order arrived even faster than the first. Great experience from checkout to doorstep.\", author: \"Talia B., Achrafieh\" }, { text: \"Love that they deliver all over Lebanon. Recommended to my cousin in the south and she got hers in 2 days.\", author: \"Rola A., Tyre\" }, { text: \"The cash on delivery option is a lifesaver. No stress about online payments.\", author: \"Zeina H., Jounieh\" }, ], repurchase: [ { text: \"Already on my third order. The Tattoo Brow is something I will never stop buying.\", author: \"Christelle M., Beirut\" }, { text: \"I bought the nose strips as a one-time try and now I reorder every month without thinking twice.\", author: \"Ola S., Broumana\" }, { text: \"I've recommended this store to five friends and two of them have already reordered themselves.\", author: \"Maya K., Hamra\" }, { text: \"First time buying was just to test. Now it's a staple in my routine. I won't use anything else.\", author: \"Sandra F., Metn\" }, { text: \"The Boob Lift tape is a repeat purchase for me every season. Never lets me down.\", author: \"Lina A., Dekwaneh\" }, { text: \"I gifted the hairline powder to my sister and she immediately ordered her own. Says it all.\", author: \"Hind T., Byblos\" }, ], }; let currentTab = 'results'; let currentPage = 0; const perPage = 3; function switchTab(tab, event) { currentTab = tab; currentPage = 0; document.querySelectorAll('.reviews-tab').forEach(btn => btn.classList.remove('active')); event.target.classList.add('active'); renderReviews(); } function renderReviews() { const reviews = allReviews[currentTab]; const totalPages = Math.ceil(reviews.length / perPage); const start = currentPage * perPage; const visible = reviews.slice(start, start + perPage); document.getElementById('reviews-grid').innerHTML = visible.map(r => <div class=\"review-card\"> <div class=\"review-card-stars\">★★★★★</div> <p class=\"review-card-text\">${r.text}</p> <span class=\"review-card-author\">${r.author}</span> </div> ).join(''); document.getElementById('reviews-dots').innerHTML = Array.from({length: totalPages}, (_, i) => <div class=\"reviews-dot ${i === currentPage ? 'active' : ''}\" onclick=\"goToPage(${i})\"></div> ).join(''); } function goToPage(page) { currentPage = page; renderReviews(); } renderReviews(); </script>",
